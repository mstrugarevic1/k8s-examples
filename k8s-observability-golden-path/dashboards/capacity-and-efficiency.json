{
  "uid": "golden-path-capacity-and-efficiency",
  "title": "Capacity and Efficiency",
  "tags": [
    "golden-path"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "links": [],
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "custom",
        "query": ".*,local,production",
        "current": {
          "text": "All",
          "value": ".*"
        },
        "includeAll": false
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(kube_namespace_status_phase, namespace)",
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      },
      {
        "name": "workload",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(namespace_workload_pod:kube_pod_owner:relabel{namespace=~\"$namespace\"}, workload)",
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "CPU Requests / Allocatable",
      "description": "Requested CPU compared with allocatable CPU.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "golden_path:cluster_cpu_request_ratio{cluster=~\"$cluster\"}",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "Memory Requests / Allocatable",
      "description": "Requested memory compared with allocatable memory.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "golden_path:cluster_memory_request_ratio{cluster=~\"$cluster\"}",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "CPU Overcommit",
      "description": "CPU limits compared with allocatable CPU.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(kube_pod_container_resource_limits{cluster=~\"$cluster\",resource=\"cpu\"}) / sum(kube_node_status_allocatable{cluster=~\"$cluster\",resource=\"cpu\"})",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "Memory Overcommit",
      "description": "Memory limits compared with allocatable memory.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(kube_pod_container_resource_limits{cluster=~\"$cluster\",resource=\"memory\"}) / sum(kube_node_status_allocatable{cluster=~\"$cluster\",resource=\"memory\"})",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "Node CPU Headroom",
      "description": "Available CPU headroom by node.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "1 - (sum by (node) (rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\",container!=\"\",image!=\"\"}[5m])) / sum by (node) (kube_node_status_allocatable{cluster=~\"$cluster\",resource=\"cpu\"}))",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "gridPos": {
        "x": 6,
        "y": 6,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "Node Memory Headroom",
      "description": "Available memory headroom by node.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "1 - (sum by (node) (container_memory_working_set_bytes{cluster=~\"$cluster\",container!=\"\",image!=\"\"}) / sum by (node) (kube_node_status_allocatable{cluster=~\"$cluster\",resource=\"memory\"}))",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 6,
        "h": 7
      },
      "type": "table",
      "title": "Top Namespaces By Usage",
      "description": "Namespaces using the most CPU.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (namespace) (rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\",namespace=~\"$namespace\",container!=\"\",image!=\"\"}[5m])))",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 8,
      "gridPos": {
        "x": 18,
        "y": 6,
        "w": 6,
        "h": 7
      },
      "type": "table",
      "title": "Top Workloads By Usage",
      "description": "Workloads using the most CPU.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (namespace,workload) (rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\",namespace=~\"$namespace\",container!=\"\",image!=\"\"}[5m]) * on(namespace,pod) group_left(workload) namespace_workload_pod:kube_pod_owner:relabel{workload=~\"$workload\"}))",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 9,
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 6,
        "h": 7
      },
      "type": "table",
      "title": "Workloads Without CPU Requests",
      "description": "Containers missing CPU requests.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (namespace,pod,container) (kube_pod_container_info{cluster=~\"$cluster\",namespace=~\"$namespace\"} unless on(namespace,pod,container) kube_pod_container_resource_requests{cluster=~\"$cluster\",resource=\"cpu\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 10,
      "gridPos": {
        "x": 6,
        "y": 13,
        "w": 6,
        "h": 7
      },
      "type": "table",
      "title": "Workloads Without Memory Requests",
      "description": "Containers missing memory requests.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (namespace,pod,container) (kube_pod_container_info{cluster=~\"$cluster\",namespace=~\"$namespace\"} unless on(namespace,pod,container) kube_pod_container_resource_requests{cluster=~\"$cluster\",resource=\"memory\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 11,
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 6,
        "h": 7
      },
      "type": "table",
      "title": "Workloads Approaching Limits",
      "description": "Containers using more than 80 percent of memory limit.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (namespace,pod,container) (container_memory_working_set_bytes{cluster=~\"$cluster\",namespace=~\"$namespace\",container!=\"\",image!=\"\"}) / sum by (namespace,pod,container) (kube_pod_container_resource_limits{cluster=~\"$cluster\",namespace=~\"$namespace\",resource=\"memory\"}) > 0.8",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 12,
      "gridPos": {
        "x": 18,
        "y": 13,
        "w": 6,
        "h": 7
      },
      "type": "table",
      "title": "Unschedulable Pods",
      "description": "Pods the scheduler cannot place.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kube_pod_status_unschedulable{cluster=~\"$cluster\",namespace=~\"$namespace\"} == 1",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 13,
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 7
      },
      "type": "table",
      "title": "PVC Usage and Remaining Capacity",
      "description": "PVC usage ratio.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kubelet_volume_stats_used_bytes{cluster=~\"$cluster\",namespace=~\"$namespace\"} / kubelet_volume_stats_capacity_bytes{cluster=~\"$cluster\",namespace=~\"$namespace\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 14,
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 7
      },
      "type": "table",
      "title": "Node Pressure Conditions",
      "description": "Active node pressure conditions.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kube_node_status_condition{cluster=~\"$cluster\",condition=~\"DiskPressure|MemoryPressure|PIDPressure\",status=\"true\"} == 1",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    }
  ]
}
