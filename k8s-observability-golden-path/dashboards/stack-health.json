{
  "uid": "golden-path-stack-health",
  "title": "Stack Health",
  "tags": ["golden-path"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "templating": {"list": [
    {"name": "cluster", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(up, cluster)", "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "namespace", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(kube_namespace_status_phase, namespace)", "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "workload", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(namespace_workload_pod:kube_pod_owner:relabel{namespace=~\"$namespace\"}, workload)", "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "pod", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(kube_pod_info{namespace=~\"$namespace\"}, pod)", "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "container", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(kube_pod_container_info{namespace=~\"$namespace\",pod=~\"$pod\"}, container)", "includeAll": true, "current": {"text": "All", "value": "$__all"}}
  ]},
  "panels": [
    {"id": 1, "type": "stat", "title": "Are Prometheus targets up?", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 6, "w": 5, "x": 0, "y": 0}, "targets": [{"expr": "sum(up == 0)"}]},
    {"id": 2, "type": "timeseries", "title": "Is Prometheus healthy?", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 6, "w": 5, "x": 5, "y": 0}, "targets": [{"expr": "prometheus_tsdb_head_series"}, {"expr": "rate(prometheus_rule_evaluation_failures_total[5m])"}]},
    {"id": 3, "type": "timeseries", "title": "Is Loki rejecting ingestion?", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 6, "w": 5, "x": 10, "y": 0}, "targets": [{"expr": "rate(loki_discarded_samples_total[5m])"}]},
    {"id": 4, "type": "timeseries", "title": "Is Fluent Bit retrying or dropping logs?", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 6, "w": 5, "x": 15, "y": 0}, "targets": [{"expr": "rate(fluentbit_output_retries_total[5m])"}, {"expr": "rate(fluentbit_output_dropped_records_total[5m])"}]},
    {"id": 5, "type": "stat", "title": "Is Alertmanager reachable?", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 6, "w": 4, "x": 20, "y": 0}, "targets": [{"expr": "sum(up{job=~\".*alertmanager.*\"} == 1)"}]}
  ]
}

