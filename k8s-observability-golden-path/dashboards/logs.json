{
  "uid": "golden-path-logs",
  "title": "Logs",
  "tags": ["golden-path"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "templating": {"list": [
    {"name": "cluster", "type": "query", "datasource": {"type": "loki", "uid": "loki"}, "query": "label_values(cluster)", "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "namespace", "type": "query", "datasource": {"type": "loki", "uid": "loki"}, "query": "label_values(namespace)", "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "workload", "type": "query", "datasource": {"type": "loki", "uid": "loki"}, "query": "label_values(workload)", "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "pod", "type": "query", "datasource": {"type": "loki", "uid": "loki"}, "query": "label_values(pod)", "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "container", "type": "query", "datasource": {"type": "loki", "uid": "loki"}, "query": "label_values(container)", "includeAll": true, "current": {"text": "All", "value": "$__all"}}
  ]},
  "panels": [
    {"id": 1, "type": "timeseries", "title": "Are error and warning logs increasing?", "datasource": {"type": "loki", "uid": "loki"}, "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0}, "targets": [{"expr": "sum by (namespace) (rate({namespace=~\"$namespace\",pod=~\"$pod\",container=~\"$container\"} |~ \"(?i)error|warn\" [5m]))"}]},
    {"id": 2, "type": "timeseries", "title": "Which namespaces and workloads produce logs?", "datasource": {"type": "loki", "uid": "loki"}, "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0}, "targets": [{"expr": "sum by (namespace, workload) (rate({namespace=~\"$namespace\",workload=~\"$workload\"}[5m]))"}]},
    {"id": 3, "type": "table", "title": "Which Pods are noisy?", "datasource": {"type": "loki", "uid": "loki"}, "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0}, "targets": [{"expr": "topk(20, sum by (namespace,pod) (rate({namespace=~\"$namespace\",pod=~\"$pod\"}[5m])))"}]},
    {"id": 4, "type": "logs", "title": "What Kubernetes warning events happened?", "datasource": {"type": "loki", "uid": "loki"}, "gridPos": {"h": 7, "w": 6, "x": 0, "y": 6}, "targets": [{"expr": "{namespace=~\"$namespace\"} |~ \"Warning\""}]},
    {"id": 5, "type": "logs", "title": "Which Pods failed scheduling?", "datasource": {"type": "loki", "uid": "loki"}, "gridPos": {"h": 7, "w": 6, "x": 6, "y": 6}, "targets": [{"expr": "{namespace=~\"$namespace\"} |~ \"FailedScheduling\""}]},
    {"id": 6, "type": "logs", "title": "Which containers are in BackOff or ImagePullBackOff?", "datasource": {"type": "loki", "uid": "loki"}, "gridPos": {"h": 7, "w": 6, "x": 12, "y": 6}, "targets": [{"expr": "{namespace=~\"$namespace\"} |~ \"BackOff|ImagePullBackOff\""}]},
    {"id": 7, "type": "logs", "title": "Which volumes failed to mount?", "datasource": {"type": "loki", "uid": "loki"}, "gridPos": {"h": 7, "w": 6, "x": 18, "y": 6}, "targets": [{"expr": "{namespace=~\"$namespace\"} |~ \"FailedMount\""}]}
  ]
}

