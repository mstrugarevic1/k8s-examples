{
  "uid": "golden-path-observability-stack-health",
  "title": "Observability Stack Health",
  "tags": [
    "golden-path"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "links": [],
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "custom",
        "query": ".*,local,production",
        "current": {
          "text": "All",
          "value": ".*"
        },
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 6
      },
      "type": "stat",
      "title": "Down Prometheus Targets",
      "description": "Targets Prometheus cannot scrape.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(up{cluster=~\"$cluster\"} == 0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 2,
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 5,
        "h": 6
      },
      "type": "timeseries",
      "title": "Prometheus Ingestion Rate",
      "description": "Samples appended per second.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(prometheus_tsdb_head_samples_appended_total{cluster=~\"$cluster\"}[5m]))",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "gridPos": {
        "x": 9,
        "y": 0,
        "w": 5,
        "h": 6
      },
      "type": "timeseries",
      "title": "Prometheus Rule Evaluation Failures",
      "description": "Rule evaluation failures.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(prometheus_rule_evaluation_failures_total{cluster=~\"$cluster\"}[5m]))",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "gridPos": {
        "x": 14,
        "y": 0,
        "w": 5,
        "h": 6
      },
      "type": "timeseries",
      "title": "Loki Ingestion Rate",
      "description": "Lines or push requests received by Loki.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(loki_distributor_lines_received_total{cluster=~\"$cluster\"}[5m])) or sum(rate(loki_request_duration_seconds_count{cluster=~\"$cluster\",route=~\".*push.*\"}[5m]))",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "gridPos": {
        "x": 19,
        "y": 0,
        "w": 5,
        "h": 6
      },
      "type": "timeseries",
      "title": "Loki Discarded Records by Reason",
      "description": "Samples discarded by Loki.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (reason) (rate(loki_discarded_samples_total{cluster=~\"$cluster\"}[5m]))",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "Loki Query Error Rate",
      "description": "Failed Loki query requests.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(loki_request_duration_seconds_count{cluster=~\"$cluster\",route=~\".*query.*\",status_code=~\"5..\"}[5m]))",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "gridPos": {
        "x": 6,
        "y": 6,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "Loki Query Latency p95",
      "description": "95th percentile Loki query latency.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(loki_request_duration_seconds_bucket{cluster=~\"$cluster\",route=~\".*query.*\"}[5m])))",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 6,
        "h": 7
      },
      "type": "table",
      "title": "Loki Ring and Component Health",
      "description": "Loki ring members by component.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "loki_ring_members{cluster=~\"$cluster\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 9,
      "gridPos": {
        "x": 18,
        "y": 6,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "Fluent Bit Input and Output Rate",
      "description": "Records read and sent by Fluent Bit.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(fluentbit_input_records_total{cluster=~\"$cluster\"}[5m])) or sum(rate(fluentbit_output_proc_records_total{cluster=~\"$cluster\"}[5m]))",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "Fluent Bit Retries",
      "description": "Output retries.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(fluentbit_output_retries_total{cluster=~\"$cluster\"}[5m]))",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "gridPos": {
        "x": 6,
        "y": 13,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "Fluent Bit Dropped Records",
      "description": "Dropped output records.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(fluentbit_output_dropped_records_total{cluster=~\"$cluster\"}[5m]))",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 6,
        "h": 6
      },
      "type": "stat",
      "title": "Alertmanager Health",
      "description": "Reachable Alertmanager targets.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(up{cluster=~\"$cluster\",job=~\".*alertmanager.*\"} == 1)",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 13,
      "gridPos": {
        "x": 18,
        "y": 13,
        "w": 6,
        "h": 6
      },
      "type": "stat",
      "title": "Grafana Availability",
      "description": "Reachable Grafana targets.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(up{cluster=~\"$cluster\",job=~\".*grafana.*\"} == 1)",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    }
  ]
}
