{
  "uid": "golden-path-workload-reliability",
  "title": "Workload Reliability",
  "tags": [
    "golden-path"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "links": [
    {
      "title": "Open filtered logs",
      "url": "/d/golden-path-logs-and-events?var-cluster=$cluster&var-namespace=$namespace&var-workload=$workload&var-pod=$pod"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "custom",
        "query": ".*,local,production",
        "current": {
          "text": "All",
          "value": ".*"
        },
        "includeAll": false
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(kube_namespace_status_phase, namespace)",
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      },
      {
        "name": "workload",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(namespace_workload_pod:kube_pod_owner:relabel{namespace=~\"$namespace\"}, workload)",
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(kube_pod_info{namespace=~\"$namespace\",pod=~\".*\"}, pod)",
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 6
      },
      "type": "timeseries",
      "title": "Desired vs Available Replicas",
      "description": "Desired and available deployment replicas.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kube_deployment_spec_replicas{cluster=~\"$cluster\",namespace=~\"$namespace\",deployment=~\"$workload\"} or kube_deployment_status_replicas_available{cluster=~\"$cluster\",namespace=~\"$namespace\",deployment=~\"$workload\"}",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 6
      },
      "type": "stat",
      "title": "Readiness Percentage",
      "description": "Ready Pods divided by selected workload Pods.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "golden_path:workload_readiness_ratio{cluster=~\"$cluster\",namespace=~\"$namespace\",workload=~\"$workload\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 3,
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 6
      },
      "type": "stat",
      "title": "Unavailable Replicas",
      "description": "Missing available replicas.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum((kube_deployment_spec_replicas{cluster=~\"$cluster\",namespace=~\"$namespace\",deployment=~\"$workload\"} - kube_deployment_status_replicas_available{cluster=~\"$cluster\",namespace=~\"$namespace\",deployment=~\"$workload\"}) > 0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 4,
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 6
      },
      "type": "table",
      "title": "Rollout Generation Mismatch",
      "description": "Deployments whose controller has not observed the latest generation.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kube_deployment_status_observed_generation{cluster=~\"$cluster\",namespace=~\"$namespace\",deployment=~\"$workload\"} != kube_deployment_metadata_generation{cluster=~\"$cluster\",namespace=~\"$namespace\",deployment=~\"$workload\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 5,
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "Restart Rate",
      "description": "Per-Pod restart rate.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "golden_path:pod_restart_rate{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\"$pod\"}",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "gridPos": {
        "x": 6,
        "y": 6,
        "w": 6,
        "h": 6
      },
      "type": "table",
      "title": "CrashLoopBackOff Pods",
      "description": "Containers currently waiting in CrashLoopBackOff.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kube_pod_container_status_waiting_reason{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\"$pod\",reason=\"CrashLoopBackOff\"} == 1",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 7,
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 6,
        "h": 6
      },
      "type": "table",
      "title": "OOMKilled Containers",
      "description": "Containers whose last termination reason was OOMKilled.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kube_pod_container_status_last_terminated_reason{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\"$pod\",reason=\"OOMKilled\"} == 1",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 8,
      "gridPos": {
        "x": 18,
        "y": 6,
        "w": 6,
        "h": 6
      },
      "type": "timeseries",
      "title": "CPU Usage / Request",
      "description": "CPU usage compared with requested CPU.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (namespace,pod) (rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\"$pod\",container!=\"\",image!=\"\"}[5m])) / sum by (namespace,pod) (kube_pod_container_resource_requests{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\"$pod\",resource=\"cpu\"})",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 6
      },
      "type": "timeseries",
      "title": "Memory Usage / Request and Limit",
      "description": "Memory usage compared with requests and limits.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (namespace,pod) (container_memory_working_set_bytes{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\"$pod\",container!=\"\",image!=\"\"}) / sum by (namespace,pod) (kube_pod_container_resource_requests{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\"$pod\",resource=\"memory\"}) or sum by (namespace,pod) (container_memory_working_set_bytes{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\"$pod\",container!=\"\",image!=\"\"}) / sum by (namespace,pod) (kube_pod_container_resource_limits{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\"$pod\",resource=\"memory\"})",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "gridPos": {
        "x": 8,
        "y": 12,
        "w": 8,
        "h": 6
      },
      "type": "timeseries",
      "title": "CPU Throttling",
      "description": "Container CPU throttling ratio.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (namespace,pod) (rate(container_cpu_cfs_throttled_periods_total{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\"$pod\"}[5m])) / sum by (namespace,pod) (rate(container_cpu_cfs_periods_total{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\"$pod\"}[5m]))",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "gridPos": {
        "x": 16,
        "y": 12,
        "w": 8,
        "h": 7
      },
      "type": "table",
      "title": "HPA Current / Desired / Max Replicas",
      "description": "HPA replica state.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{cluster=~\"$cluster\",namespace=~\"$namespace\",horizontalpodautoscaler=~\"$workload\"} or kube_horizontalpodautoscaler_status_desired_replicas{cluster=~\"$cluster\",namespace=~\"$namespace\",horizontalpodautoscaler=~\"$workload\"} or kube_horizontalpodautoscaler_spec_max_replicas{cluster=~\"$cluster\",namespace=~\"$namespace\",horizontalpodautoscaler=~\"$workload\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 12,
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 8,
        "h": 7
      },
      "type": "table",
      "title": "PDB Disruptions Allowed",
      "description": "Allowed voluntary disruptions.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kube_poddisruptionbudget_status_pod_disruptions_allowed{cluster=~\"$cluster\",namespace=~\"$namespace\",poddisruptionbudget=~\"$workload\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 13,
      "gridPos": {
        "x": 8,
        "y": 19,
        "w": 16,
        "h": 7
      },
      "type": "table",
      "title": "Pod Table",
      "description": "Pod name, node and owner metadata for the selected workload.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kube_pod_info{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\"$pod\"}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    }
  ]
}
