{
  "uid": "golden-path-capacity",
  "title": "Capacity",
  "tags": ["golden-path"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "templating": {"list": [
    {"name": "cluster", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(up, cluster)", "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "namespace", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(kube_namespace_status_phase, namespace)", "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "workload", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(namespace_workload_pod:kube_pod_owner:relabel{namespace=~\"$namespace\"}, workload)", "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "pod", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(kube_pod_info{namespace=~\"$namespace\"}, pod)", "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "container", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(kube_pod_container_info{namespace=~\"$namespace\",pod=~\"$pod\"}, container)", "includeAll": true, "current": {"text": "All", "value": "$__all"}}
  ]},
  "panels": [
    {"id": 1, "type": "timeseries", "title": "Is CPU usage above requests?", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0}, "targets": [{"expr": "golden_path:namespace_cpu_usage_ratio{namespace=~\"$namespace\"}"}]},
    {"id": 2, "type": "timeseries", "title": "Is memory usage above requests?", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0}, "targets": [{"expr": "golden_path:namespace_memory_usage_ratio{namespace=~\"$namespace\"}"}]},
    {"id": 3, "type": "table", "title": "Which namespaces use the most CPU and memory?", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0}, "targets": [{"expr": "sum by (namespace) (rate(container_cpu_usage_seconds_total{container!=\"\",image!=\"\"}[5m]))"}, {"expr": "sum by (namespace) (container_memory_working_set_bytes{container!=\"\",image!=\"\"})"}]},
    {"id": 4, "type": "stat", "title": "Is cluster CPU overcommitted?", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0}, "targets": [{"expr": "sum(kube_pod_container_resource_requests{resource=\"cpu\"}) / sum(kube_node_status_allocatable{resource=\"cpu\"})"}]},
    {"id": 5, "type": "table", "title": "Which Pods are unschedulable?", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 6, "w": 6, "x": 0, "y": 6}, "targets": [{"expr": "kube_pod_status_unschedulable{namespace=~\"$namespace\"}"}]},
    {"id": 6, "type": "table", "title": "Which nodes report pressure?", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 6, "w": 6, "x": 6, "y": 6}, "targets": [{"expr": "kube_node_status_condition{condition=~\"DiskPressure|MemoryPressure|PIDPressure\",status=\"true\"}"}]},
    {"id": 7, "type": "timeseries", "title": "Which persistent volumes are filling?", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 6, "w": 6, "x": 12, "y": 6}, "targets": [{"expr": "kubelet_volume_stats_used_bytes{namespace=~\"$namespace\"} / kubelet_volume_stats_capacity_bytes{namespace=~\"$namespace\"}"}]},
    {"id": 8, "type": "table", "title": "Which workloads lack requests?", "datasource": {"type": "prometheus", "uid": "prometheus"}, "gridPos": {"h": 6, "w": 6, "x": 18, "y": 6}, "targets": [{"expr": "sum by (namespace,pod,container) (kube_pod_container_info{namespace=~\"$namespace\"} unless on(namespace,pod,container) kube_pod_container_resource_requests)"}]}
  ]
}

