{
  "uid": "golden-path-cluster-overview",
  "title": "Cluster Overview",
  "tags": [
    "golden-path"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "links": [],
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "custom",
        "query": ".*,local,production",
        "current": {
          "text": "All",
          "value": ".*"
        },
        "includeAll": false
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(kube_namespace_status_phase, namespace)",
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 6
      },
      "type": "stat",
      "title": "Ready Nodes / Total Nodes",
      "description": "Percentage of Kubernetes nodes reporting Ready.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(kube_node_status_condition{cluster=~\"$cluster\",condition=\"Ready\",status=\"true\"}) / count(kube_node_status_condition{cluster=~\"$cluster\",condition=\"Ready\",status=\"true\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 2,
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 6
      },
      "type": "stat",
      "title": "Unavailable Workloads",
      "description": "Deployments or StatefulSets missing ready replicas.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum((kube_deployment_spec_replicas{cluster=~\"$cluster\",namespace=~\"$namespace\"} - kube_deployment_status_replicas_available{cluster=~\"$cluster\",namespace=~\"$namespace\"}) > 0) + sum((kube_statefulset_replicas{cluster=~\"$cluster\",namespace=~\"$namespace\"} - kube_statefulset_status_replicas_ready{cluster=~\"$cluster\",namespace=~\"$namespace\"}) > 0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 3,
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 6
      },
      "type": "stat",
      "title": "Pods Pending > 15m",
      "description": "Pods that have been Pending long enough to require action.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum((time() - kube_pod_created{cluster=~\"$cluster\",namespace=~\"$namespace\"}) * on(namespace,pod) group_left() (kube_pod_status_phase{cluster=~\"$cluster\",namespace=~\"$namespace\",phase=\"Pending\"} == 1) > 900)",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 4,
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 6
      },
      "type": "stat",
      "title": "Active Alerts",
      "description": "Pending or firing alerts.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(ALERTS{cluster=~\"$cluster\",alertstate=~\"pending|firing\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 5,
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 8,
        "h": 6
      },
      "type": "timeseries",
      "title": "Recent Restart Rate",
      "description": "Pod restart rate across selected namespaces.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(golden_path:pod_restart_rate{cluster=~\"$cluster\",namespace=~\"$namespace\"})",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "gridPos": {
        "x": 8,
        "y": 6,
        "w": 8,
        "h": 6
      },
      "type": "timeseries",
      "title": "CPU Requests / Allocatable",
      "description": "Reserved CPU compared with allocatable CPU.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "golden_path:cluster_cpu_request_ratio{cluster=~\"$cluster\"}",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "gridPos": {
        "x": 16,
        "y": 6,
        "w": 8,
        "h": 6
      },
      "type": "timeseries",
      "title": "Memory Requests / Allocatable",
      "description": "Reserved memory compared with allocatable memory.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "golden_path:cluster_memory_request_ratio{cluster=~\"$cluster\"}",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 6
      },
      "type": "timeseries",
      "title": "CPU and Memory Headroom",
      "description": "Remaining allocatable capacity after requests.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "1 - golden_path:cluster_cpu_request_ratio{cluster=~\"$cluster\"} or 1 - golden_path:cluster_memory_request_ratio{cluster=~\"$cluster\"}",
          "instant": false,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "gridPos": {
        "x": 8,
        "y": 12,
        "w": 8,
        "h": 7
      },
      "type": "table",
      "title": "Top Namespaces With Unhealthy Workloads",
      "description": "Namespaces with non-running Pods.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (namespace) (kube_pod_status_phase{cluster=~\"$cluster\",namespace=~\"$namespace\",phase=~\"Pending|Failed\"} > 0))",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 10,
      "gridPos": {
        "x": 16,
        "y": 12,
        "w": 8,
        "h": 7
      },
      "type": "table",
      "title": "Node Pressure Conditions",
      "description": "Nodes reporting pressure conditions.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "kube_node_status_condition{cluster=~\"$cluster\",condition=~\"DiskPressure|MemoryPressure|PIDPressure\",status=\"true\"} == 1",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "0"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    }
  ]
}
