{
  "uid": "golden-path-logs-and-events",
  "title": "Logs and Events",
  "tags": [
    "golden-path"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "links": [],
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "custom",
        "query": ".*,local,production",
        "current": {
          "text": "All",
          "value": ".*"
        },
        "includeAll": false
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(namespace)",
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      },
      {
        "name": "workload",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(workload)",
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      },
      {
        "name": "pod",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(pod)",
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      },
      {
        "name": "container",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values(container)",
        "includeAll": true,
        "current": {
          "text": "All",
          "value": ".*"
        },
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 6
      },
      "type": "timeseries",
      "title": "Kubernetes Event Rate by Reason",
      "description": "Kubernetes Events from Fluent Bit kubernetes_events input.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (reason,type) (rate({cluster=~\"$cluster\",source=\"kubernetes-events\",namespace=~\"$namespace\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 6
      },
      "type": "timeseries",
      "title": "Log Volume by Namespace and Workload",
      "description": "Container log volume.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (namespace,workload) (rate({cluster=~\"$cluster\",source=\"container\",namespace=~\"$namespace\",workload=~\"$workload\"} | pod=~\"$pod\" [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 6
      },
      "type": "timeseries",
      "title": "Error and Warning Log Rate",
      "description": "Application warning/error log rate.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (namespace,workload) (rate({cluster=~\"$cluster\",source=\"container\",namespace=~\"$namespace\",workload=~\"$workload\",container=~\"$container\"} | pod=~\"$pod\" |~ \"(?i)error|warn|exception|failed\" [5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 8,
        "h": 6
      },
      "type": "timeseries",
      "title": "Noisiest Workloads",
      "description": "Highest log-producing workloads.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (namespace,workload) (rate({cluster=~\"$cluster\",source=\"container\",namespace=~\"$namespace\",workload=~\"$workload\"} | pod=~\"$pod\" [5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "gridPos": {
        "x": 8,
        "y": 6,
        "w": 8,
        "h": 10
      },
      "type": "logs",
      "title": "Kubernetes Warning Events",
      "description": "Warning Events collected from the Kubernetes API.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{cluster=~\"$cluster\",source=\"kubernetes-events\",namespace=~\"$namespace\",type=\"Warning\",reason=~\"FailedScheduling|FailedMount|BackOff|Unhealthy|ImagePullBackOff|Killing\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false
      }
    },
    {
      "id": 6,
      "gridPos": {
        "x": 16,
        "y": 6,
        "w": 8,
        "h": 10
      },
      "type": "logs",
      "title": "Container Logs Explorer",
      "description": "Container logs filtered by namespace, workload, Pod metadata and container.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{cluster=~\"$cluster\",source=\"container\",namespace=~\"$namespace\",workload=~\"$workload\",container=~\"$container\"} | pod=~\"$pod\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false
      }
    }
  ]
}
