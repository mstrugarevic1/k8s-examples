    {
      "id": 7,
      "title": "CPU Utilization",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "golden_path:cluster_cpu_utilization_ratio",
          "legendFormat": "CPU",
          "instant": true
        }
      ],
      "description": "Cluster CPU usage as a share of allocatable CPU.",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 6,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.85
              }
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
