{
  "uid": "golden-path-workload-health",
  "title": "Workload Health",
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "tags": ["golden-path"],
  "templating": {"list": [
    {"name": "namespace", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(kube_namespace_status_phase, namespace)", "refresh": 1, "multi": false, "includeAll": false, "current": {"text": "golden-path-demo", "value": "golden-path-demo"}},
    {"name": "workload", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(namespace_workload_pod:kube_pod_owner:relabel{namespace=\"$namespace\"}, workload)", "refresh": 1, "multi": true, "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "pod", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(kube_pod_info{namespace=\"$namespace\"}, pod)", "refresh": 1, "multi": true, "includeAll": true, "current": {"text": "All", "value": "$__all"}},
    {"name": "container", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(kube_pod_container_info{namespace=\"$namespace\",pod=~\"$pod\"}, container)", "refresh": 1, "multi": true, "includeAll": true, "current": {"text": "All", "value": "$__all"}}
  ]},
  "panels": [
    {"id": 1, "title": "Desired vs Available Replicas", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"refId": "A", "expr": "kube_deployment_spec_replicas{namespace=\"$namespace\",deployment=~\"$workload\"}"}, {"refId": "B", "expr": "kube_deployment_status_replicas_available{namespace=\"$namespace\",deployment=~\"$workload\"}"}]},
    {"id": 2, "title": "Workload Readiness Ratio", "type": "gauge", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"refId": "A", "expr": "golden_path:workload_readiness_ratio{namespace=\"$namespace\",workload=~\"$workload\"}"}]},
    {"id": 3, "title": "Unavailable Replicas", "type": "table", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"refId": "A", "expr": "golden_path:workload_unavailable_replicas{namespace=\"$namespace\",workload=~\"$workload\"} > 0"}]},
    {"id": 4, "title": "CrashLoopBackOff Containers", "type": "table", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"refId": "A", "expr": "kube_pod_container_status_waiting_reason{namespace=\"$namespace\",pod=~\"$pod\",container=~\"$container\",reason=\"CrashLoopBackOff\"} == 1"}]},
    {"id": 5, "title": "Recent Restarts", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"refId": "A", "expr": "sum by (pod) (golden_path:pod_restart_rate{namespace=\"$namespace\",pod=~\"$pod\"})"}]},
    {"id": 6, "title": "Last OOMKilled Containers", "type": "table", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"refId": "A", "expr": "kube_pod_container_status_last_terminated_reason{namespace=\"$namespace\",pod=~\"$pod\",container=~\"$container\",reason=\"OOMKilled\"} == 1"}]},
    {"id": 7, "title": "CPU Usage vs Request", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"refId": "A", "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"$namespace\",pod=~\"$pod\",container=~\"$container\",container!=\"\",image!=\"\"}[5m])) / clamp_min(sum by (pod) (kube_pod_container_resource_requests{namespace=\"$namespace\",pod=~\"$pod\",container=~\"$container\",resource=\"cpu\"}), 0.001)"}]},
    {"id": 8, "title": "Memory Working Set vs Request and Limit", "type": "timeseries", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"refId": "A", "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"$namespace\",pod=~\"$pod\",container=~\"$container\",container!=\"\",image!=\"\"}) / clamp_min(sum by (pod) (kube_pod_container_resource_requests{namespace=\"$namespace\",pod=~\"$pod\",container=~\"$container\",resource=\"memory\"}), 1)"}, {"refId": "B", "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"$namespace\",pod=~\"$pod\",container=~\"$container\",container!=\"\",image!=\"\"}) / clamp_min(sum by (pod) (kube_pod_container_resource_limits{namespace=\"$namespace\",pod=~\"$pod\",container=~\"$container\",resource=\"memory\"}), 1)"}]},
    {"id": 9, "title": "Pods Failing Readiness", "type": "table", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"refId": "A", "expr": "kube_pod_status_ready{namespace=\"$namespace\",pod=~\"$pod\",condition=\"false\"} == 1"}]},
    {"id": 10, "title": "Rollout Age", "type": "table", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"refId": "A", "expr": "time() - kube_deployment_created{namespace=\"$namespace\",deployment=~\"$workload\"}"}]},
    {"id": 11, "title": "HPA Constrained State", "type": "table", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"refId": "A", "expr": "kube_horizontalpodautoscaler_status_condition{namespace=\"$namespace\",horizontalpodautoscaler=~\"$workload\",condition=\"ScalingLimited\",status=\"true\"}"}]},
    {"id": 12, "title": "PDB Disruption Allowance", "type": "table", "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"refId": "A", "expr": "kube_poddisruptionbudget_status_pod_disruptions_allowed{namespace=\"$namespace\",poddisruptionbudget=~\"$workload\"}"}]}
  ]
}
